// Schéma Prisma — Chantiers Essaouira
//
// Refonte Lieu / Poste / Paiement (session 2026-05-18, voir docs/JOURNAL.md
// entrée du 2026-05-17 pour le cadrage métier complet).
//
// Modélisation à trois niveaux : CLIENT → LIEU → POSTE
//   - CLIENT : un Utilisateur avec role='client'
//   - LIEU   : un bien immobilier où Ludimmo intervient en continu
//              (1 client → N lieux, 1 lieu → 1 client)
//   - POSTE  : une intervention chiffrée sur un Lieu (ex: "3 tables marbre",
//              "contrôle piscine"). 1 Poste = 1 ligne de devis unique.
//              Les Paiements sont rattachés au Poste, libres au fil de l'eau
//              (pas d'échéancier 30/40/30).
//
// SQLite pour dev local :
//   - Pas d'enum Prisma natif → toutes les énumérations sont en `String`
//     avec validation zod côté routes. Les valeurs autorisées sont
//     documentées en commentaire au-dessus de chaque champ concerné.
//   - Pour le déploiement production sur le VPS, on basculera sur PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// UTILISATEURS ET RÔLES
// ============================================================
// role: 'admin' | 'chef' | 'client'
//   (le rôle 'sous_traitant' a été retiré en V1 : Rachid est 'chef',
//   pas de modélisation distincte des sous-traitants ouvriers)
//
// email et motDePasseHash sont optionnels :
//   - un client créé via la modale du formulaire Lieu peut ne pas avoir
//     d'email (saisie facultative)
//   - un compte sans motDePasseHash ne peut PAS se connecter (garde
//     dans routes/auth.js POST /login → 401 identifiants incorrects,
//     message générique pour ne pas révéler l'existence du compte)
// En SQLite, plusieurs NULL ne sont pas considérés égaux pour UNIQUE,
// donc l'unicité de l'email reste assurée pour les non-null.

model Utilisateur {
  id              Int       @id @default(autoincrement())
  email           String?   @unique
  motDePasseHash  String?   @map("mot_de_passe_hash")
  prenom          String
  nom             String
  telephone       String?
  adresse         String?
  notes           String?
  role            String    // 'admin' | 'chef' | 'client'
  partDefautPct   Int       @default(50) @map("part_defaut_pct")
  actif           Boolean   @default(true)
  creeLe          DateTime  @default(now()) @map("cree_le")
  modifieLe       DateTime  @updatedAt @map("modifie_le")

  // Relations Lieu
  lieuxChef       Lieu[]    @relation("ChefLieu")
  lieuxClient     Lieu[]    @relation("ClientLieu")

  // Auth
  refreshTokens   RefreshToken[]

  // Compta — dépenses & budgets
  depensesSaisies   Depense[]    @relation("DepenseSaisiePar")
  depensesValidees  Depense[]    @relation("DepenseValideePar")
  depensesCorrigees Depense[]    @relation("DepenseCorrigeePar")
  budgetsRecus      BudgetLieu[] @relation("BudgetDestinataire")
  budgetsCrees      BudgetLieu[] @relation("BudgetCreePar")

  @@map("utilisateurs")
}

model RefreshToken {
  id            Int         @id @default(autoincrement())
  token         String      @unique
  utilisateurId Int         @map("utilisateur_id")
  expireLe      DateTime    @map("expire_le")
  creeLe        DateTime    @default(now()) @map("cree_le")

  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ============================================================
// PARAMÈTRES GLOBAUX
// ============================================================
// Purgé en session 2026-05-18 : suppression des champs liés à
// l'échéancier 30/40/30 (pctAcompte, pctMiChantier, pctSolde,
// joursAvantRelanceAcompte), à la marge auto (margeDefautPct) et au
// partage Yassine/Rachid (baseCommission). Ces logiques ne sont pas
// en V1 du nouveau modèle.

model Reglages {
  id                       Int      @id @default(1)

  // Véhicule (frais kilométriques — formule dans lib/fraisKm.js)
  vehiculeModele           String   @default("VW Touareg V6 TDI 2015-2016") @map("vehicule_modele")
  consommationL100km       Float    @default(9.5) @map("consommation_l_100km")
  prixGasoilCentimes       Int      @default(1150) @map("prix_gasoil_centimes")
  usureCentimesParKm       Int      @default(80) @map("usure_centimes_par_km")
  securiteAllerRetour      Int      @default(1) @map("securite_aller_retour")

  // Entreprise (en-tête PDF, signatures, etc.)
  entrepriseNom            String   @default("Ludimmo Travaux") @map("entreprise_nom")
  entrepriseAdresse        String   @default("480 Borj 1, 44010 Essaouira") @map("entreprise_adresse")
  entrepriseTel            String   @default("+212 6 87 19 86 36") @map("entreprise_tel")
  entrepriseEmail          String   @default("ludimmo.essaouira@gmail.com") @map("entreprise_email")

  modifieLe                DateTime @updatedAt @map("modifie_le")

  @@map("reglages")
}

// ============================================================
// LIEU — un bien immobilier où Ludimmo intervient en continu
// ============================================================
// statut: 'PROSPECT' | 'EN_COURS' | 'TERMINE'
//
// Le statut est une colonne stockée mais calculée par le backend à
// partir de l'état des Postes rattachés (cf. service de recalcul
// dans routes/postes.js et la route admin cachée
// POST /api/admin/recalculer-statuts). Règles :
//   - PROSPECT  : aucun Poste, OU tous les Postes sont A_FAIRE
//   - EN_COURS  : au moins un Poste EN_COURS, OU mix A_FAIRE/TERMINE
//   - TERMINE   : tous les Postes sont TERMINE (et il y en a au moins un)
//
// La référence L-2026-NNN est générée côté backend (compteur annuel).

model Lieu {
  id                      Int       @id @default(autoincrement())
  reference               String    @unique
  nom                     String

  // Acteurs
  clientId                Int       @map("client_id")
  chefId                  Int?      @map("chef_id")

  client                  Utilisateur  @relation("ClientLieu", fields: [clientId], references: [id])
  chef                    Utilisateur? @relation("ChefLieu", fields: [chefId], references: [id])

  // Adresse précise du lieu (libre, peut différer de l'adresse du client)
  adresse                 String

  // Budget estimatif (informatif uniquement, pas un engagement)
  budgetEstimatifCentimes Int?      @map("budget_estimatif_centimes")

  // Statut calculé (cf. règles en en-tête de modèle)
  statut                  String    @default("PROSPECT")

  // Frais kilométriques — calculés selon Reglages au create/update du Lieu
  distanceAllerKm         Int?      @map("distance_aller_km")
  nombreAllerRetourPrevu  Int?      @map("nombre_aller_retour_prevu")
  fraisEssenceCentimes    Int       @default(0) @map("frais_essence_centimes")

  notes                   String?

  creeLe                  DateTime  @default(now()) @map("cree_le")
  modifieLe               DateTime  @updatedAt @map("modifie_le")

  // Relations — onDelete:
  //   Postes:        Restrict (un Lieu avec Postes ne se supprime pas)
  //   Depense.lieuId: Restrict (traçabilité comptable)
  //   BudgetLieu:    Restrict (idem)
  // En V1 il n'y a de toute façon pas de route DELETE /api/lieux/:id.
  postes                  Poste[]
  depenses                Depense[]
  budgets                 BudgetLieu[]

  @@map("lieux")
  @@index([clientId])
  @@index([chefId])
  @@index([statut])
}

// ============================================================
// POSTE — une intervention chiffrée sur un Lieu (= devis 1 ligne)
// ============================================================
// statut: 'A_FAIRE' | 'EN_COURS' | 'TERMINE'
//
// 1 Poste = 1 ligne unique. Pas de modèle LigneDevis séparé. Les
// montants sont saisis directement par l'admin.
//
// Machine à états pour le chef (validation backend dans
// routes/postes.js PATCH /:id) :
//   - A_FAIRE  → EN_COURS  : autorisé
//   - EN_COURS → TERMINE   : autorisé
//   - TERMINE  → EN_COURS  : autorisé (correction d'erreur)
//   - TERMINE  → A_FAIRE   : interdit (chef)
//   - EN_COURS → A_FAIRE   : interdit (chef)
// L'admin garde toutes les transitions libres (peut tout corriger).
//
// termineLe est renseigné automatiquement par le backend quand le
// statut passe à TERMINE, et remis à null si on en sort. Sert au
// tri du dashboard admin "créances à recouvrer".
//
// Champs montants (montantBrutCentimes, montantClientCentimes,
// margeCentimes, margePourcent) : strippés de la réponse API quand
// req.user.role === 'chef' (defense in depth).

model Poste {
  id                    Int       @id @default(autoincrement())
  lieuId                Int       @map("lieu_id")

  titre                 String
  description           String?
  ordre                 Int       @default(0)

  // Statut + horodatage du passage en TERMINE
  statut                String    @default("A_FAIRE")
  termineLe             DateTime? @map("termine_le")

  // Montants (réservés admin, strippés pour chef côté API)
  montantBrutCentimes   Int       @default(0) @map("montant_brut_centimes")
  montantClientCentimes Int       @default(0) @map("montant_client_centimes")
  margeCentimes         Int       @default(0) @map("marge_centimes")
  margePourcent         Float     @default(0) @map("marge_pourcent")

  creeLe                DateTime  @default(now()) @map("cree_le")
  modifieLe             DateTime  @updatedAt @map("modifie_le")

  // Relations — onDelete:
  //   Lieu→Poste:     Restrict (déclaré côté Lieu via la FK ci-dessous)
  //   Paiement:       Restrict (protège la traçabilité financière)
  //   Photo:          Cascade  (les photos d'un Poste supprimé partent avec)
  //   Depense.posteId: SetNull (la dépense reste rattachée au Lieu)
  //   BudgetLieu.posteId: SetNull (idem)
  //
  // En pratique la route DELETE /api/postes/:id pré-vérifie zéro
  // Paiement ET zéro Dépense rattachés et retourne 409 sinon — le
  // Restrict reste comme filet de sécurité ultime.
  lieu                  Lieu        @relation(fields: [lieuId], references: [id], onDelete: Restrict)
  paiements             Paiement[]
  photos                Photo[]
  depenses              Depense[]
  budgets               BudgetLieu[]

  @@map("postes")
  @@index([lieuId])
  @@index([statut])
  @@index([termineLe])
}

// ============================================================
// PAIEMENT — versement client rattaché à un Poste
// ============================================================
// mode: 'CASH' | 'VIREMENT'
//
// Plusieurs paiements possibles par Poste, libres au fil de l'eau.
// Pas d'échéancier, pas de "type" (acompte/mi_chantier/solde), pas
// de "statut" (attendu/recu) — le paiement existe = il a été reçu.

model Paiement {
  id              Int       @id @default(autoincrement())
  posteId         Int       @map("poste_id")
  date            DateTime
  montantCentimes Int       @map("montant_centimes")
  mode            String    // 'CASH' | 'VIREMENT'
  description     String?

  creeLe          DateTime  @default(now()) @map("cree_le")

  // onDelete Restrict côté Poste : on ne supprime pas un Poste qui a
  // des paiements (vérification applicative + filet Prisma).
  poste           Poste     @relation(fields: [posteId], references: [id], onDelete: Restrict)

  @@map("paiements")
  @@index([posteId])
}

// ============================================================
// PHOTO — module préparé mais sans API en V1
// ============================================================
// Modèle créé pour anticiper le module Photos (avant/après par
// intervention). Aucune route Fastify ne l'expose en V1 — sera ajouté
// dans une session ultérieure. Stockage prévu sous
// /uploads/postes/{posteId}/, servi en static par Caddy.

model Photo {
  id              Int       @id @default(autoincrement())
  posteId         Int       @map("poste_id")
  cheminFichier   String    @map("chemin_fichier")
  titre           String?
  description     String?
  prisLe          DateTime? @map("pris_le")
  uploadeLe       DateTime  @default(now()) @map("uploade_le")

  poste           Poste     @relation(fields: [posteId], references: [id], onDelete: Cascade)

  @@map("photos")
  @@index([posteId])
}

// ============================================================
// COMPTA — DÉPENSES (cash Rachid + factures fournisseurs)
// ============================================================
// categorie : 'ACOMPTE' | 'MATERIEL' | 'REPAS' (validé côté zod)
// statut    : 'A_VALIDER' | 'VALIDEE'
//
// Cycle de vie inchangé par rapport à la version pré-refonte :
//   - Saisie chef          → A_VALIDER
//   - Saisie admin         → VALIDEE auto
//   - Chef peut modifier/supprimer sa propre dépense tant que A_VALIDER
//   - Admin peut valider ou modifier (modif → lock auto, audit corrigee*)
//   - Une dépense VALIDEE est verrouillée pour le chef
//
// Nouveautés refonte :
//   - lieuId  obligatoire (ex-chantierId), onDelete Restrict
//   - posteId optionnel : affectation fine à un Poste, onDelete SetNull
//     (si on supprime le Poste, la dépense reste sur le Lieu)
//   - fournisseur texte libre (pas de modèle Fournisseur persistant en V1)

model Depense {
  id                       Int       @id @default(autoincrement())
  lieuId                   Int       @map("lieu_id")
  posteId                  Int?      @map("poste_id")
  saisieParId              Int       @map("saisie_par_id")

  date                     DateTime
  categorie                String    // 'ACOMPTE' | 'MATERIEL' | 'REPAS'
  montantCentimes          Int       @map("montant_centimes")
  description              String
  fournisseur              String?   // texte libre, pas de FK
  estAvancePersonnelle     Boolean   @default(false) @map("est_avance_personnelle")

  statut                   String    @default("A_VALIDER")
  valideeParId             Int?      @map("validee_par_id")
  valideeLe                DateTime? @map("validee_le")
  corrigeeParId            Int?      @map("corrigee_par_id")
  corrigeeLe               DateTime? @map("corrigee_le")

  creeLe                   DateTime  @default(now()) @map("cree_le")
  modifieLe                DateTime  @updatedAt @map("modifie_le")

  lieu                     Lieu         @relation(fields: [lieuId], references: [id], onDelete: Restrict)
  poste                    Poste?       @relation(fields: [posteId], references: [id], onDelete: SetNull)
  saisiePar                Utilisateur  @relation("DepenseSaisiePar", fields: [saisieParId], references: [id])
  valideePar               Utilisateur? @relation("DepenseValideePar", fields: [valideeParId], references: [id])
  corrigeePar              Utilisateur? @relation("DepenseCorrigeePar", fields: [corrigeeParId], references: [id])

  @@map("depenses")
  @@index([lieuId])
  @@index([posteId])
  @@index([statut])
}

// ============================================================
// COMPTA — BUDGETS LIEU (cash Dominique → Rachid)
// ============================================================
// type :
//   - 'VERSEMENT'     : Dominique donne du cash à Rachid pour démarrer
//   - 'REMBOURSEMENT' : Dominique rembourse une avance personnelle Rachid
//
// Renommé depuis BudgetChantier. Nouveautés refonte :
//   - lieuId  obligatoire (ex-chantierId), onDelete Restrict
//   - posteId optionnel : un versement peut être affecté à un Poste
//     précis ou rester global au Lieu. onDelete SetNull.

model BudgetLieu {
  id              Int       @id @default(autoincrement())
  lieuId          Int       @map("lieu_id")
  posteId         Int?      @map("poste_id")
  userId          Int       @map("user_id")         // destinataire (Rachid en général)
  date            DateTime
  montantCentimes Int       @map("montant_centimes")
  type            String    // 'VERSEMENT' | 'REMBOURSEMENT'
  description     String?
  creeParId       Int       @map("cree_par_id")
  creeLe          DateTime  @default(now()) @map("cree_le")

  lieu            Lieu        @relation(fields: [lieuId], references: [id], onDelete: Restrict)
  poste           Poste?      @relation(fields: [posteId], references: [id], onDelete: SetNull)
  user            Utilisateur @relation("BudgetDestinataire", fields: [userId], references: [id])
  creePar         Utilisateur @relation("BudgetCreePar", fields: [creeParId], references: [id])

  @@map("budgets_lieu")
  @@index([lieuId])
  @@index([posteId])
  @@index([userId])
}
